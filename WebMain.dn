const int SERVER_PORT= 8080

component provides App requires io.Output out, data.IntUtil iu, net.TCPSocket, net.TCPServerSocket, 
    http.HTTPUtil httpUtil {
	
    void handleRequest(TCPSocket s) {
		HTTPMessage httpMessage = httpUtil.readHTTPRequest(s)
		if (httpMessage != null) {
            out.println("TESTANDO")
            out.println("$(httpMessage.command) - $(httpMessage.resource) - $(httpMessage.queryString)")


			/*if (httpMessage.resourceExists) {
                File fd = new File(httpMessage.resource, File.FILE_ACCESS_READ)
