                int tl = 0
                while ((fbuf = fd.read(HTTPUtil.BUFF_SIZE)).arrayLength > 0) {
                    tl += fbuf.arrayLength
                    httpMessage.socket.send(fbuf)
                }
                fd.close()
            } else {
