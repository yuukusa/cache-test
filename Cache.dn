component provides Cache requires io.Output out, data.IntUtil iu {
    int mru_order[] = new int[Cache.MAX_SIZE]  // indices in access order
    int order_size = 0  // current number of entries in MRU
    const char mode[] = "Most Recently Used (MRU)"
    
    void initCache() {
        cache = new CacheItem[Cache.MAX_SIZE]
        index = 0
        hits = 0
        misses = 0
        order_size = 0
    }
    
    // Item was accessed -> move to most recently used position
    void updateMRUOrder(int cache_index) {
        int display_index = cache_index + 1 // start display index at 1
        int pos = 0
        int found = 0
        for (int i = 0; i < order_size; i++) { // find where in mru_order where the item index is
            if (mru_order[i] == display_index) {
                pos = i
                found = 1
                break
            }
        }
        for (int i = pos; i < order_size - 1; i++) { // shift left (erase found item) and
            mru_order[i] = mru_order[i + 1]
        }
        mru_order[order_size - 1] = display_index // reintroduce at the end (MRU position)
    }
    
    void addToMRUOrder(int cache_index) {
        int display_index = cache_index + 1
        mru_order[order_size] = display_index
        order_size = order_size + 1
    }
    
    int Cache:get(int key) {
        if (cache == null) { 
            initCache() 
        }
        
        for (int i = 0; i < Cache.MAX_SIZE; i++) {
            if (cache[i] != null) {
                if (cache[i].key == key) {
                    hits++
                    updateMRUOrder(i)
                    return cache[i].value
                }
            } else { 
                break 
            }
        }
        
        misses++
        return INT_MAX
    }
    
    void Cache:add(store CacheItem item) {
        if (cache == null) { 
            initCache() 
        }
        
        int flag = 0
        
        // if key already exists, then update
        for (int i = 0; i < Cache.MAX_SIZE; i++) {
            if (cache[i] != null && cache[i].key == item.key) {
                cache[i] = item
                updateMRUOrder(i)
                flag = 1
                break
            }
        }
        
        // if key does not exist, find next empty spot
        if (flag == 0) {
            for (int i = 0; i < Cache.MAX_SIZE; i++) {
                if (cache[i] == null) {
                    cache[i] = item
                    addToMRUOrder(i)
                    flag = 1
                    break
                }
            }
        }
        
        // no empty spot found, thus evict and add
        if (flag == 0) {
            int mru_display = mru_order[order_size - 1] // MRU
            int mru_index = mru_display - 1
            cache[mru_index] = item // replace
            // Remove the last element by reducing order_size
            order_size = order_size - 1
            
            // Add the new index at the end
            addToMRUOrder(mru_index)
        }
    }
    
    void Cache:printCache() {
        if (cache == null) { 
            initCache() 
        }
        out.println("$mode")
        out.print("[ ")
        for (int i = 0; i < Cache.MAX_SIZE; i++) {
            if (cache[i] == null) { 
                break 
            }
            out.print("$(iu.intToString(cache[i].key))-$(iu.intToString(cache[i].value))  ")
        }
        out.print("]\n")
        out.println("Hits: $(iu.intToString(hits)) - Misses: $(iu.intToString(misses))")
        
        out.print("Access order: [")
        for (int i = 0; i < order_size; i++) {
            out.print(" $(iu.intToString(mru_order[i]))")
        }
        out.print(" ]\n")
        out.println("---------------------------")
    }
    
    int Cache:getHits() {
        return hits
    }
    
    int Cache:getMisses() {
        return misses
    }
}