component provides Cache
{
    static Mutex cacheLock = new Mutex()
    int Cache:get(int cache[], int key)       // look for match, return position or data
    {
        mutex(cacheLock)
        {
            for (int i = 0; i < 100; i++)
            {
                if (cache[i] == key)
                { 
                    return cache[i]           // Return the found data
                    // return i               // return found data position
                }
            }
        }
        return 404  // Not found in cache
    }

    int[] Cache:update(int cache[], int current_size, int key)
    {
        return cache
    }

    int[] Cache:delete(int cache[], int current_size, int key)
    {
        mutex(cacheLock)
        {
            int temp[] = new int [current_size]
            int j = 0
            int localArraySize = current_size
            for(int i; i < localArraySize; i++)
            {
                if (key != cache[i])
                {
                    temp[j] = cache[i]
                    j++
                }
                if (key == cache[i])
                    localArraySize--
            }
            return temp
        }
    }
}